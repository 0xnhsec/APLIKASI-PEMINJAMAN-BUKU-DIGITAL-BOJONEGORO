	<queryString language="SQL">
		<![CDATA[SELECT
     transaksi.`id_transaksi` AS transaksi_id_transaksi,
     transaksi.`id_user` AS transaksi_id_user,
     transaksi.`name` AS transaksi_name,
     transaksi.`id_petugas` AS transaksi_id_petugas,
     transaksi.`nama_petugas` AS transaksi_nama_petugas,
     transaksi.`id_barang` AS transaksi_id_barang,
     transaksi.`name_barang` AS transaksi_name_barang,
     transaksi.`harga` AS transaksi_harga,
     transaksi.`Date` AS transaksi_Date,
     transaksi.`kategori` AS transaksi_kategori,
     transaksi.`jumlah_beli` AS transaksi_jumlah_beli,
     transaksi.`kode_diskon` AS transaksi_kode_diskon,
     transaksi.`nominal_diskon` AS transaksi_nominal_diskon,
     transaksi.`All_harga_awal` AS transaksi_All_harga_awal,
     transaksi.`All_harga_akhir` AS transaksi_All_harga_akhir,
     transaksi.`total_harga` AS transaksi_total_harga,
     transaksi.`bayar` AS transaksi_bayar,
     transaksi.`kembalian` AS transaksi_kembalian,
     transaksi.`pesan` AS transaksi_pesan
FROM
     `transaksi` transaksi]]>
	</queryString>
